# FramePost — environment template. Copy to .env and fill in.
# Never commit .env. .env.example may be committed (no secrets).

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Comma-separated Fernet keys (first encrypts, all decrypt). Supports rotation.
# Generate with: docker compose exec backend python -m admin generate-encryption-key
TOKEN_ENCRYPTION_KEY=

# Flickr — register at https://www.flickr.com/services/apps/create
FLICKR_API_KEY=
FLICKR_API_SECRET=

# Phase 5 — Claude Vision tag suggestions
ANTHROPIC_API_KEY=

# Defaults — override only if you know why
DATABASE_URL=sqlite:////app/data/framepost.db
PHOTO_ROOT=/mnt/photo-data
